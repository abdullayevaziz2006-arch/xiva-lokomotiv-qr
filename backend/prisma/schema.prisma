generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            Int            @id @default(autoincrement())
  fullName      String
  phone         String         @unique
  passwordHash  String
  role          String         // admin, tadbirkor, kassir
  createdAt     DateTime       @default(now())
  createdCodes  QRCode[]       @relation("CreatedBy")
  carousels     Carousel[]
}

model Terminal {
  id         Int        @id @default(autoincrement())
  name       String
  ipAddress  String
  port       String     @default("80")
  username   String
  password   String     // password shifrlangan holatda saqlanishi tavsiya qilinadi
  status     String     @default("active")
  carousels  Carousel[]
}

model Carousel {
  id             Int        @id @default(autoincrement())
  name           String
  description    String?
  entrepreneurId Int
  terminalId     Int

  entrepreneur   User       @relation(fields: [entrepreneurId], references: [id])
  terminal       Terminal   @relation(fields: [terminalId], references: [id])
  qrCodes        QRCodeCarousel[]
}

model QRCode {
  id         Int      @id @default(autoincrement())
  qrString   String   @unique
  status     Int      @default(0) // 0-yaratildi, -1 bekor qilindi
  expiresAt  DateTime
  createdBy  Int
  customerName String?  // AES-256 bilan shifrlangan ism-familiya
  customerPhone String? // AES-256 bilan shifrlangan telefon raqami
  createdAt  DateTime @default(now())

  creator    User     @relation("CreatedBy", fields: [createdBy], references: [id])
  carousels  QRCodeCarousel[]
}

model QRCodeCarousel {
  id         Int      @id @default(autoincrement())
  qrCodeId   Int
  carouselId Int
  status     Int      @default(0) // 0 - Aktiv (kirmagan), 1 - Ishlatilgan, -1 - Vozvrat qilingan (Refund)
  usedAt     DateTime? // qachon kirgani

  qrCode   QRCode   @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  carousel Carousel @relation(fields: [carouselId], references: [id], onDelete: Cascade)

  @@unique([qrCodeId, carouselId])
}
